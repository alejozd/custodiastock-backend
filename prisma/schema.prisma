generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  delivered Delivery[] @relation("DeliveredBy")
  received  Delivery[] @relation("ReceivedBy")
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String
  code        String     @unique
  description String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  deliveries  Delivery[]
}

model Delivery {
  id             Int      @id @default(autoincrement())
  productId      Int
  quantity       Int
  deliveredById  Int
  receivedById   Int
  signatureImage String   @db.LongText
  createdAt      DateTime @default(now())

  product     Product @relation(fields: [productId], references: [id])
  deliveredBy User    @relation("DeliveredBy", fields: [deliveredById], references: [id])
  receivedBy  User    @relation("ReceivedBy", fields: [receivedById], references: [id])

  @@index([productId])
  @@index([deliveredById])
  @@index([receivedById])
}
