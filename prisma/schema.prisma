generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OPERATOR
  ADMIN
}

enum DeliveryStatus {
  ACTIVE
  CANCELED
}

enum EntryStatus {
  ACTIVE
  CANCELED
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  fullName  String
  email     String?   @unique
  password  String
  role      UserRole  @default(OPERATOR) @map("rol")
  active    Boolean   @default(true) @map("activo")
  createdAt DateTime  @default(now()) @map("creadoEn")
  deletedAt DateTime? @map("eliminadoEn")

  delivered          Delivery[] @relation("DeliveredBy")
  received           Delivery[] @relation("ReceivedBy")
  canceledDeliveries Delivery[] @relation("CanceledBy")
  entries            Entry[]    @relation("CreatedBy")
  canceledEntries    Entry[]    @relation("EntryCanceledBy")

  @@map("Usuario")
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String    @map("nombre")
  reference   String    @unique
  description String?   @map("descripcion")
  active      Boolean   @default(true) @map("activo")
  createdAt   DateTime  @default(now()) @map("creadoEn")
  deletedAt   DateTime? @map("eliminadoEn")

  deliveryItems DeliveryItem[]
  entryItems    EntryItem[]

  @@map("Producto")
}

model Delivery {
  id             Int            @id @default(autoincrement())
  documentNumber String         @unique @map("numeroDocumento") @db.VarChar(20)
  deliveredById  Int            @map("entregadorId")
  receivedById   Int            @map("receptorId")
  signatureImage String         @map("firma") @db.LongText
  status         DeliveryStatus @default(ACTIVE) @map("estado")
  canceledAt     DateTime?      @map("anuladoEn")
  canceledById   Int?           @map("anuladoPorId")
  cancelReason   String?        @map("motivoAnulacion")
  deliveryDate   DateTime?       @map("fechaEntrega")
  createdAt      DateTime       @default(now()) @map("fecha")
  deletedAt      DateTime?      @map("eliminadoEn")

  deliveredBy User           @relation("DeliveredBy", fields: [deliveredById], references: [id])
  receivedBy  User           @relation("ReceivedBy", fields: [receivedById], references: [id])
  canceledBy  User?          @relation("CanceledBy", fields: [canceledById], references: [id])
  items       DeliveryItem[]

  @@map("Entrega")
}

model DeliveryItem {
  id         Int       @id @default(autoincrement())
  deliveryId Int       @map("entregaId")
  productId  Int       @map("productoId")
  quantity   Int       @map("cantidad")
  deletedAt  DateTime? @map("eliminadoEn")

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@map("DetalleEntrega")
}

model Entry {
  id             Int         @id @default(autoincrement())
  documentNumber String      @unique @map("numeroDocumento") @db.VarChar(20)
  sourceDocument String?     @map("documentoOrigen") @db.VarChar(50)
  userId         Int         @map("usuarioId")
  status         EntryStatus @default(ACTIVE) @map("estado")
  canceledAt     DateTime?   @map("anuladoEn")
  canceledById   Int?        @map("anuladoPorId")
  cancelReason   String?     @map("motivoAnulacion")
  entryDate      DateTime?   @map("fechaEntrada")
  createdAt      DateTime    @default(now()) @map("fecha")
  deletedAt      DateTime?   @map("eliminadoEn")

  createdBy  User        @relation("CreatedBy", fields: [userId], references: [id])
  canceledBy User?       @relation("EntryCanceledBy", fields: [canceledById], references: [id])
  items      EntryItem[]

  @@map("Entrada")
}

model EntryItem {
  id        Int       @id @default(autoincrement())
  entryId   Int       @map("entradaId")
  productId Int       @map("productoId")
  quantity  Int       @map("cantidad")
  deletedAt DateTime? @map("eliminadoEn")

  entry   Entry   @relation(fields: [entryId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("DetalleEntrada")
}

model Sequence {
  id         Int    @id @default(autoincrement())
  name       String @unique @map("nombre")
  prefix     String @default("") @map("prefijo")
  nextNumber Int    @default(1) @map("siguienteNumero")

  @@map("Secuencia")
}
