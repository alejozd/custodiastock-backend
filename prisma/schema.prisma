generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @map("nombre")
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("creadoEn")

  delivered Delivery[] @relation("DeliveredBy")
  received  Delivery[] @relation("ReceivedBy")

  @@map("Usuario")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @map("nombre")
  code        String   @unique @map("codigo")
  description String?  @map("descripcion")
  createdAt   DateTime @default(now()) @map("creadoEn")

  deliveryItems DeliveryItem[]

  @@map("Producto")
}

model Delivery {
  id             Int      @id @default(autoincrement())
  deliveredById  Int      @map("entregadorId")
  receivedById   Int      @map("receptorId")
  signatureImage String   @map("firma") @db.LongText
  createdAt      DateTime @default(now()) @map("fecha")

  deliveredBy User           @relation("DeliveredBy", fields: [deliveredById], references: [id])
  receivedBy  User           @relation("ReceivedBy", fields: [receivedById], references: [id])
  items       DeliveryItem[]

  @@map("Entrega")
}

model DeliveryItem {
  id         Int @id @default(autoincrement())
  deliveryId Int @map("entregaId")
  productId  Int @map("productoId")
  quantity   Int @map("cantidad")

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@map("DetalleEntrega")
}
